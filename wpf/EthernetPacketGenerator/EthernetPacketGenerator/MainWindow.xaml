<Window x:Class="EthernetPacketGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EthernetPacketGenerator.ViewModels"
        xmlns:views="clr-namespace:EthernetPacketGenerator.Views"
        Title="Ethernet Packet Generator"
        Icon="Assets/app.ico"
        Width="1680" Height="1000"
        MinWidth="1200" MinHeight="800"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        RenderOptions.BitmapScalingMode="NearestNeighbor">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Packet" Command="{Binding PacketListVM.AddPacketCommand}"/>
                <Separator/>
                <MenuItem Header="_Save..." Command="{Binding SaveCommand}"/>
                <MenuItem Header="_Open..." Command="{Binding LoadCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="Refresh Interfaces" Command="{Binding SendVM.RefreshInterfacesCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Height="22">
            <StatusBarItem>
                <TextBlock Text="{Binding SendVM.StartTime}" FontSize="11"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock FontSize="11">
                    <Run Text="Items: "/>
                    <Run Text="{Binding PacketListVM.Sequence.Count, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- Tabs: Build & Send | Live Capture -->
        <TabControl x:Name="MainTabs">
            <TabItem Header="Build &amp; Send">

        <!-- Root: work area | protocol palette -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"   MinWidth="900"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="180" MinWidth="150"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════
                 Work area: top-half (fields) + bottom-half (list + send)
                 ══════════════════════════════════════════ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <!-- Top: Block Builder + Protocol Fields | HEX+Tree+Events -->
                    <RowDefinition Height="*"   MinHeight="400"/>
                    <RowDefinition Height="5"/>
                    <!-- Bottom: Packet List -->
                    <RowDefinition Height="200" MinHeight="120"/>
                    <RowDefinition Height="5"/>
                    <!-- Send bar -->
                    <RowDefinition Height="Auto" MinHeight="110"/>
                </Grid.RowDefinitions>

                <!-- ── Top section ── -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <!-- Left: Block Builder + Protocol Fields -->
                        <ColumnDefinition Width="*" MinWidth="350"/>
                        <ColumnDefinition Width="5"/>
                        <!-- Right: HEX DUMP + Decode Tree + Event Palette -->
                        <ColumnDefinition Width="*" MinWidth="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Block Builder (top) + Protocol Fields (rest) -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="90" MinHeight="70"/>  <!-- Block Builder -->
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="*" MinHeight="200"/>  <!-- Protocol Fields -->
                        </Grid.RowDefinitions>

                        <views:BlockBuilderView Grid.Row="0"
                            x:Name="BlockBuilder"
                            DataContext="{Binding BlockBuilderVM}"/>

                        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                                      Background="{StaticResource BorderBrush}"/>

                        <views:ProtocolSettingsView Grid.Row="2"
                            DataContext="{Binding BlockBuilderVM.SelectedBlock}"/>
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                  Background="{StaticResource BorderBrush}"/>

                    <!-- Right: HEX DUMP + Decode Tree -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="160" MinHeight="80"/>  <!-- HEX DUMP -->
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="*"   MinHeight="120"/> <!-- Decode Tree -->
                        </Grid.RowDefinitions>

                        <views:HexDumpView Grid.Row="0"
                                           DataContext="{Binding HexDumpVM}"/>

                        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                                      Background="{StaticResource BorderBrush}"/>

                        <views:TreeDecodeView Grid.Row="2"
                                              DataContext="{Binding TreeDecodeVM}"/>
                    </Grid>
                </Grid>

                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                              Background="{StaticResource BorderBrush}"/>

                <!-- ── Packet List (full width) ── -->
                <views:PacketListView Grid.Row="2"
                                      DataContext="{Binding PacketListVM}"/>

                <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch"
                              Background="{StaticResource BorderBrush}"/>

                <!-- ── Send bar (full width) ── -->
                <views:SendControlView Grid.Row="4"
                                       DataContext="{Binding SendVM}"/>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"/>

            <!-- Right column: Protocol Palette (top) + Event Palette (bottom)
                 Event palette bottom edge aligns with Packet List top:
                 PacketList=200 + splitter=5 + Send=56 + splitter=5 = 266px -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"   MinHeight="200"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*" MinHeight="100"/>
                </Grid.RowDefinitions>

                <views:ProtocolPaletteView Grid.Row="0"
                    x:Name="ProtocolPalette"
                    DataContext="{Binding BlockBuilderVM}"/>

                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                              Background="{StaticResource BorderBrush}"/>

                <views:EventPaletteView Grid.Row="2"
                                        DataContext="{Binding PacketListVM}"/>
            </Grid>
        </Grid>

            </TabItem>

            <TabItem Header="Live Capture">
                <views:CaptureView DataContext="{Binding CaptureVM}"/>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
