<UserControl x:Class="EthernetPacketGenerator.Views.CaptureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}"
             FontFamily="Segoe UI" FontSize="12">

    <DockPanel Background="{StaticResource BackgroundBrush}">

        <!-- ══ Top Toolbar ═════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <DockPanel>
                <!-- Right: packet counter -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource MutedForeground}" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,4,0">
                        <Run Text="Packets: "/>
                        <Run Text="{Binding TotalPackets, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Left: interface + buttons -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox ItemsSource="{Binding Interfaces}"
                              SelectedItem="{Binding SelectedInterface}"
                              DisplayMemberPath="Description"
                              Width="300" Height="24"
                              FontFamily="Consolas" FontSize="10"
                              Margin="0,0,8,0"/>
                    <Button Command="{Binding StartCommand}"
                            Height="24" Padding="12,0" Margin="0,0,4,0"
                            FontWeight="SemiBold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="▶  Start"/>
                                <Setter Property="Background" Value="#2A5A2A"/>
                                <Setter Property="Foreground" Value="#5EE87A"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3A7A3A"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Command="{Binding StopCommand}"
                            Height="24" Padding="12,0" Margin="0,0,4,0"
                            FontWeight="SemiBold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="■  Stop"/>
                                <Setter Property="Background" Value="#5A2A2A"/>
                                <Setter Property="Foreground" Value="#FF8080"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#7A3A3A"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Opacity" Value="0.4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Clear"
                            Command="{Binding ClearCommand}"
                            Height="24" Padding="10,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══ Status bar ══════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,3">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="10"
                       Foreground="{StaticResource MutedForeground}"/>
        </Border>

        <!-- ══ Packet list ══════════════════════════════════════════════════ -->
        <ListView ItemsSource="{Binding Packets}"
                  Background="{StaticResource BackgroundBrush}"
                  BorderThickness="0"
                  FontFamily="Consolas" FontSize="11"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">

            <!-- Wireshark-style protocol row colors -->
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0,1"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Protocol}" Value="ARP">
                            <Setter Property="Background" Value="#1EF79316"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Protocol}" Value="UDP">
                            <Setter Property="Background" Value="#127C3AED"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Protocol}" Value="TCP">
                            <Setter Property="Background" Value="#126366F1"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Protocol}" Value="ICMP">
                            <Setter Property="Background" Value="#12A855F7"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Protocol}" Value="IPv6">
                            <Setter Property="Background" Value="#0C6366F1"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>

            <!-- Column header style -->
            <ListView.Resources>
                <Style TargetType="GridViewColumnHeader">
                    <Setter Property="Background"      Value="{StaticResource SurfaceAltBrush}"/>
                    <Setter Property="Foreground"      Value="{StaticResource MutedForeground}"/>
                    <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Padding"         Value="4,3"/>
                    <Setter Property="FontSize"        Value="10"/>
                    <Setter Property="FontWeight"      Value="SemiBold"/>
                </Style>
            </ListView.Resources>

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="No."      Width="50"  DisplayMemberBinding="{Binding No}"/>
                    <GridViewColumn Header="Time"     Width="80"  DisplayMemberBinding="{Binding Time}"/>
                    <GridViewColumn Header="Source"   Width="150" DisplayMemberBinding="{Binding SrcMac}"/>
                    <GridViewColumn Header="Dest"     Width="150" DisplayMemberBinding="{Binding DstMac}"/>
                    <GridViewColumn Header="Protocol" Width="70">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Protocol}" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Protocol}" Value="ARP">
                                                    <Setter Property="Foreground" Value="#F79316"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Protocol}" Value="UDP">
                                                    <Setter Property="Foreground" Value="#A070F0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Protocol}" Value="TCP">
                                                    <Setter Property="Foreground" Value="#8090F0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Protocol}" Value="IPv4">
                                                    <Setter Property="Foreground" Value="#5EE87A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Protocol}" Value="IPv6">
                                                    <Setter Property="Foreground" Value="#7090FF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Len"  Width="55"  DisplayMemberBinding="{Binding Length}"/>
                    <GridViewColumn Header="Info" Width="600" DisplayMemberBinding="{Binding Info}"/>
                </GridView>
            </ListView.View>
        </ListView>

    </DockPanel>
</UserControl>
