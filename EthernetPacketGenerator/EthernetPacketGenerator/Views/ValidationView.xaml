<UserControl x:Class="EthernetPacketGenerator.Views.ValidationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:EthernetPacketGenerator.Models"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}"
             FontFamily="Consolas" FontSize="12">

    <UserControl.Resources>
        <Style x:Key="ResultRowStyle" TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:PacketValidationStatus.Matched}">
                    <Setter Property="Foreground" Value="#5EE87A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:PacketValidationStatus.Mismatch}">
                    <Setter Property="Foreground" Value="#FFB347"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:PacketValidationStatus.Lost}">
                    <Setter Property="Foreground" Value="#FF6B6B"/>
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"     Value="#252535"/>
            <Setter Property="CornerRadius"   Value="4"/>
            <Setter Property="Padding"        Value="10,6"/>
            <Setter Property="Margin"         Value="3,0"/>
            <Setter Property="MinWidth"       Value="78"/>
        </Style>
        <Style x:Key="CardLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize"   Value="10"/>
        </Style>
        <Style x:Key="CardValue" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource ForegroundBrush}"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="FontWeight"  Value="Bold"/>
        </Style>
        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#888"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,6,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 설정 -->
            <RowDefinition Height="3"/>      <!-- 진행 바 -->
            <RowDefinition Height="Auto"/>   <!-- 요약 -->
            <RowDefinition Height="*"/>      <!-- 결과 -->
        </Grid.RowDefinitions>

        <!-- ═══ 설정 패널 ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1A1A2A" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- TX -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                        <TextBlock Text="TX" Style="{StaticResource RowLabel}"/>
                        <ComboBox Width="196" ItemsSource="{Binding InterfaceEntries}"
                                  SelectedItem="{Binding TxInterface}"
                                  DisplayMemberPath="ShortName"/>
                    </StackPanel>
                    <!-- RX -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                        <TextBlock Text="RX" Style="{StaticResource RowLabel}"/>
                        <ComboBox Width="196" ItemsSource="{Binding InterfaceEntries}"
                                  SelectedItem="{Binding RxInterface}"
                                  DisplayMemberPath="ShortName"
                                  IsEnabled="{Binding RxEnabled}"/>
                        <CheckBox Content="TX와 동일" IsChecked="{Binding SameInterface}"
                                  Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,14,0"/>
                    <!-- 반복 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                        <TextBlock Text="반복" Style="{StaticResource RowLabel}"/>
                        <TextBox Width="48" Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <!-- 타임아웃 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                        <TextBlock Text="타임아웃 ms" Style="{StaticResource RowLabel}"/>
                        <TextBox Width="58" Text="{Binding TimeoutMs, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <!-- 간격 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                        <TextBlock Text="간격 ms" Style="{StaticResource RowLabel}"/>
                        <TextBox Width="48" Text="{Binding InterPacketMs, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <!-- 매칭 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                        <TextBlock Text="매칭" Style="{StaticResource RowLabel}"/>
                        <ComboBox Width="148" ItemsSource="{Binding MatchModes}"
                                  SelectedItem="{Binding MatchMode}"/>
                    </StackPanel>
                    <!-- BPF 필터 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                        <TextBlock Text="RX 필터" Style="{StaticResource RowLabel}"/>
                        <TextBox Width="158" Text="{Binding RxFilter, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="BPF 필터 (예: ether dst ff:ff:ff:ff:ff:ff)"/>
                    </StackPanel>
                    <!-- 선택만 -->
                    <CheckBox Content="선택 패킷만" IsChecked="{Binding SelectedOnly}"
                              VerticalAlignment="Center" Margin="0,0,10,0"/>
                </WrapPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{Binding RunLabel}" Command="{Binding RunCommand}"
                            MinWidth="110" Margin="0,0,6,0"
                            Background="{StaticResource AccentBrush}"
                            Foreground="White" FontWeight="Bold"/>
                    <Button Content="초기화" Command="{Binding ClearCommand}" MinWidth="60"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ 진행 바 ═════════════════════════════════════════════════════════ -->
        <ProgressBar Grid.Row="1"
                     Value="{Binding ProgressValue}" Maximum="{Binding ProgressMax}"
                     Foreground="{StaticResource AccentBrush}"
                     Background="#252535" BorderThickness="0"/>

        <!-- ═══ 요약 ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#18182A" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <WrapPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="TX"   Style="{StaticResource CardLabel}"/>
                            <TextBlock Text="{Binding SummaryTx}" Style="{StaticResource CardValue}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="RX"   Style="{StaticResource CardLabel}"/>
                            <TextBlock Text="{Binding SummaryRx}" Style="{StaticResource CardValue}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="일치"  Style="{StaticResource CardLabel}"/>
                            <TextBlock Text="{Binding SummaryMatch}" Foreground="#5EE87A" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="불일치" Style="{StaticResource CardLabel}"/>
                            <TextBlock Text="{Binding SummaryMismatch}" Foreground="#FFB347" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="손실"  Style="{StaticResource CardLabel}"/>
                            <TextBlock Text="{Binding SummaryLost}" Foreground="#FF6B6B" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Separator Width="1" Background="{StaticResource BorderBrush}" Margin="6,4"/>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="손실률"  Style="{StaticResource CardLabel}"/>
                            <TextBlock Text="{Binding SummaryLossRate}"  Foreground="#FF6B6B" FontSize="13"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="일치율"  Style="{StaticResource CardLabel}"/>
                            <TextBlock Text="{Binding SummaryMatchRate}" Foreground="#5EE87A" FontSize="13"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="평균지연" Style="{StaticResource CardLabel}"/>
                            <TextBlock Text="{Binding SummaryLatency}"  Style="{StaticResource CardValue}" FontSize="13"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="경과"   Style="{StaticResource CardLabel}"/>
                            <TextBlock Text="{Binding SummaryElapsed}"  Style="{StaticResource CardValue}" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                           Foreground="#888" VerticalAlignment="Center"
                           FontSize="11" Margin="12,0,0,0" MaxWidth="300"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- ═══ 결과 테이블 ═════════════════════════════════════════════════════ -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Results}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="True" CanUserResizeRows="False"
                  SelectionMode="Single"
                  RowStyle="{StaticResource ResultRowStyle}"
                  Background="{StaticResource BackgroundBrush}"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#2A2A3A"
                  BorderThickness="0"
                  ColumnHeaderHeight="24" RowHeight="22"
                  FontFamily="Consolas" FontSize="12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#"      Binding="{Binding Index}"       Width="44"/>
                <DataGridTextColumn Header="상태"   Binding="{Binding StatusText}"  Width="110"/>
                <DataGridTextColumn Header="전송 B" Binding="{Binding SentLength}"  Width="70"/>
                <DataGridTextColumn Header="수신 B" Binding="{Binding RecvLength}"  Width="70"/>
                <DataGridTextColumn Header="지연"   Binding="{Binding LatencyText}" Width="90"/>
                <DataGridTextColumn Header="비고"   Binding="{Binding Note}"        Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
